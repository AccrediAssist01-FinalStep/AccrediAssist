# ===========================================
# AccrediAssist Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -------------------------------------------
# Server
# -------------------------------------------
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# -------------------------------------------
# MongoDB
# -------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/accrediassist?retryWrites=true&w=majority

# -------------------------------------------
# Authentication (Sprint 2+)
# -------------------------------------------
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# -------------------------------------------
# AI (Sprint 3+)
# -------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1

# -------------------------------------------
# Cloudinary (Sprint 3+)
# -------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -------------------------------------------
# WhatsApp (Sprint 3+)
# -------------------------------------------
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_ALLOWED_GROUPS=Computer Department,Training & Placement

# -------------------------------------------
# CORS
# -------------------------------------------
FRONTEND_URL=http://localhost:3000
